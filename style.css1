body{margin:0;padding:0;font-family:Arial;background:#111;color:#fff;text-align:center;}
.container{max-width:1000px;margin:50px auto;padding:20px;}
h1{color:#ff9900;} h2{color:#6a5acd;}
.buttons{margin-top:40px;display:flex;justify-content:center;flex-wrap:wrap;gap:15px;}
button{background:#6a5acd;border:none;padding:12px 25px;font-size:16px;border-radius:10px;cursor:pointer;transition:0.3s;}
button:hover{background:#ff9900;color:#000;}
ul.features{list-style:none;display:flex;flex-wrap:wrap;justify-content:center;gap:20px;padding:0;}
ul.features li{background: rgba(255,255,255,0.1);padding:20px;border-radius:15px;width:250px;transition:0.3s;}
ul.features li:hover{transform: translateY(-10px);background: rgba(255,255,255,0.2);}
ul.features img{width:50px;margin-bottom:10px;}
img.dashboard{width:100%;margin-top:40px;border-radius:15px;box-shadow:0 0 20px rgba(255,255,255,0.2);}
.ai-card, .campaign-card, .blog-card, .stat-card{background: rgba(255,255,255,0.05);padding:20px;margin:15px;border-radius:15px;}
table{width:100%;border-collapse:collapse;margin-top:20px;}
table th, table td{border:1px solid #444;padding:10px;}
table th{background:#222;}
